# Get TELEGRAM_API_ID and TELEGRAM_API_HASH from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Your phone number in international format, e.g. +14155552671
TELEGRAM_PHONE=+1234567890

# Telegram group: use @username, invite link, or exact group name
TELEGRAM_GROUP=@your_group_or_channel

# How many recent messages to scan (increase if you want more history)
FETCH_LIMIT=200

# Folder where images + analysis are saved
OUTPUT_DIR=./output

# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
